<view class="page-container">
  <!-- 顶部导航栏 -->
  <view class="header">
    <view class="header-content">
      <view class="header-left">
        <text class="title">📁 腾讯云COS文件管理器</text>
      </view>
      <view class="header-actions">
        <view class="theme-toggle" bindtap="toggleTheme">
          <text>{{ isDark ? '☀️' : '🌙' }}</text>
        </view>
        <t-button size="small" theme="default" icon="setting" bindtap="openConfig">配置</t-button>
        <t-button size="small" theme="primary" icon="refresh" loading="{{ listLoading }}" bindtap="fetchFileList">刷新</t-button>
      </view>
    </view>
  </view>

  <!-- 文件上传区 -->
  <view class="upload-section card">
    <t-button theme="primary" icon="upload" bindtap="chooseFile">选择文件上传</t-button>
    <text class="upload-tip">建议一次上传不超过 10 份文件</text>
    
    <!-- 上传队列 -->
    <view wx:if="{{ uploadQueue.length > 0 }}" class="upload-queue">
      <view wx:for="{{ uploadQueue }}" wx:key="index" class="upload-item">
        <text class="upload-name">{{ item.name }}</text>
        <text class="upload-status {{ item.status }}">{{ item.status === 'uploading' ? '上传中...' : item.status === 'success' ? '✓' : '✗' }}</text>
      </view>
    </view>
  </view>

  <!-- 文件列表 -->
  <view class="file-list-section card">
    <!-- 列表头部 -->
    <view class="list-header">
      <text class="list-title">☁️ 存储桶文件列表</text>
      <view class="list-actions" wx:if="{{ selectedFiles.length > 0 }}">
        <text class="selected-count">已选择 {{ selectedFiles.length }} 个</text>
        <t-button theme="danger" size="small" icon="delete" bindtap="batchDelete">批量删除</t-button>
      </view>
    </view>

    <!-- 文件表格 -->
    <view wx:if="{{ fileList.length > 0 }}" class="file-table">
      <!-- 表头 -->
      <view class="table-header">
        <view class="th th-checkbox">
          <t-checkbox checked="{{ isAllSelected }}" bindchange="toggleSelectAll" />
        </view>
        <view class="th th-name">文件名</view>
        <view class="th th-size">大小</view>
        <view class="th th-op">操作</view>
      </view>

      <!-- 表体 -->
      <scroll-view scroll-y class="table-body">
        <view wx:for="{{ paginatedFiles }}" wx:key="key" class="table-row {{ selectedFiles.includes(item.key) ? 'selected' : '' }}">
          <view class="td td-checkbox">
            <t-checkbox checked="{{ selectedFiles.includes(item.key) }}" bindchange="toggleSelect" data-key="{{ item.key }}" />
          </view>
          <view class="td td-name" bindtap="openFile" data-file="{{ item }}">
            <text class="file-name">{{ item.name }}</text>
          </view>
          <view class="td td-size">{{ formatSize(item.size) }}</view>
          <view class="td td-op">
            <view class="op-buttons">
              <t-button theme="primary" size="small" variant="outline" icon="browse" bindtap="previewFile" data-file="{{ item }}">预览</t-button>
              <t-button theme="success" size="small" variant="outline" icon="download" bindtap="downloadFile" data-file="{{ item }}">下载</t-button>
              <t-button theme="danger" size="small" variant="outline" icon="delete" bindtap="deleteFile" data-file="{{ item }}">删除</t-button>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 空状态 -->
    <view wx:elif="{{ !listLoading }}" class="empty-state">
      <text class="empty-icon">📂</text>
      <text class="empty-text">存储桶为空</text>
      <t-button theme="primary" icon="refresh" bindtap="fetchFileList">刷新列表</t-button>
    </view>

    <!-- 加载状态 -->
    <view wx:else class="loading-state">
      <text>加载中...</text>
    </view>

    <!-- 分页 -->
    <view wx:if="{{ fileList.length > 0 }}" class="pagination">
      <t-button theme="default" size="small" variant="outline" icon="chevron-left" bindtap="prevPage" disabled="{{ currentPage <= 1 }}">上一页</t-button>
      <text class="page-info">{{ currentPage }} / {{ totalPages }}</text>
      <t-button theme="default" size="small" variant="outline" icon="chevron-right" bindtap="nextPage" disabled="{{ currentPage >= totalPages }}">下一页</t-button>
    </view>
  </view>

  <!-- Toast -->
  <t-toast id="t-toast" />
</view>
