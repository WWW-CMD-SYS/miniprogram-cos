<view class="page-container">
  <!-- 顶部导航栏 -->
  <view class="header">
    <view class="header-content">
      <view class="header-left">
        <view class="logo-area">
          <view class="logo-icon">☁️</view>
          <view class="title-area">
            <text class="title">COS 文件管理器</text>
            <text class="subtitle">腾讯云对象存储</text>
          </view>
        </view>
      </view>
      <view class="header-actions">
        <view class="theme-btn" bindtap="toggleTheme">
          <t-icon name="{{ isDark ? 'sun' : 'moon' }}" size="40rpx" />
        </view>
        <view class="btn-group">
          <t-button size="small" theme="light" variant="outline" icon="setting" bindtap="openConfig">配置</t-button>
          <t-button size="small" theme="primary" icon="refresh" loading="{{ listLoading }}" bindtap="fetchFileList">刷新</t-button>
        </view>
      </view>
    </view>
  </view>

  <!-- 文件上传区 -->
  <view class="upload-section card">
    <t-button theme="primary" size="large" icon="upload" shape="round" bindtap="chooseFile">选择文件上传</t-button>
    <text class="upload-tip">支持多文件上传，建议一次不超过 10 份</text>
    
    <!-- 上传队列 -->
    <view wx:if="{{ uploadQueue.length > 0 }}" class="upload-queue">
      <view wx:for="{{ uploadQueue }}" wx:key="index" class="upload-item">
        <view class="upload-info">
          <t-icon name="file" size="32rpx" />
          <text class="upload-name">{{ item.name }}</text>
        </view>
        <text class="upload-status {{ item.status }}">
          <text wx:if="{{ item.status === 'uploading' }}">上传中...</text>
          <text wx:elif="{{ item.status === 'success' }}">✓ 已完成</text>
          <text wx:elif="{{ item.status === 'fail' }}">✗ 失败</text>
        </text>
      </view>
    </view>
  </view>

  <!-- 文件列表 -->
  <view class="file-list-section card">
    <!-- 列表头部 -->
    <view class="list-header">
      <view class="list-title-area">
        <t-icon name="folder-open" size="36rpx" />
        <text class="list-title">存储桶文件</text>
        <view class="file-count" wx:if="{{ fileList.length > 0 }}">{{ fileList.length }} 个文件</view>
      </view>
      <view class="list-actions" wx:if="{{ selectedFiles.length > 0 }}">
        <view class="selected-badge">
          <text>已选 {{ selectedFiles.length }}</text>
        </view>
        <t-button theme="danger" size="small" variant="outline" icon="delete" bindtap="batchDelete">批量删除</t-button>
      </view>
    </view>

    <!-- 文件表格 - 带斑马纹样式 -->
    <view wx:if="{{ fileList.length > 0 }}" class="file-table">
      <!-- 表头 -->
      <view class="table-header">
        <view class="th th-checkbox">
          <t-checkbox checked="{{ isAllSelected }}" bindchange="toggleSelectAll" />
        </view>
        <view class="th th-name">文件名</view>
        <view class="th th-op">操作</view>
      </view>

      <!-- 表体 -->
      <scroll-view scroll-y class="table-body">
        <view wx:for="{{ paginatedFiles }}" wx:key="key" 
              class="table-row zebra-{{ index % 2 === 0 ? 'odd' : 'even' }} {{ selectedFiles.includes(item.key) ? 'selected' : '' }}">
          <view class="td td-checkbox">
            <t-checkbox checked="{{ selectedFiles.includes(item.key) }}" bindchange="toggleSelect" data-key="{{ item.key }}" />
          </view>
          <view class="td td-name" bindtap="openFile" data-file="{{ item }}">
            <view class="file-info">
              <t-icon name="{{ item.type === 'image' ? 'image' : item.type === 'pdf' ? 'file-pdf' : 'file' }}" size="40rpx" />
              <text class="file-name">{{ item.name }}</text>
            </view>
          </view>
          <view class="td td-op">
            <view class="action-btns">
              <view class="action-btn" catchtap="previewFile" data-file="{{ item }}" title="预览">
                <t-icon name="browse" size="38rpx" color="#0052d9" />
              </view>
              <view class="action-btn" catchtap="downloadFile" data-file="{{ item }}" title="下载">
                <t-icon name="download" size="38rpx" color="#00875a" />
              </view>
              <view class="action-btn action-btn-danger" catchtap="deleteFile" data-file="{{ item }}" title="删除">
                <t-icon name="delete" size="38rpx" color="#d54941" />
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 空状态 -->
    <view wx:elif="{{ !listLoading }}" class="empty-state">
      <view class="empty-icon-area">
        <t-icon name="file-clear" size="120rpx" />
      </view>
      <text class="empty-text">存储桶为空</text>
      <text class="empty-hint">点击上方按钮上传文件</text>
      <t-button theme="primary" variant="outline" icon="upload" bindtap="chooseFile">上传文件</t-button>
    </view>

    <!-- 加载状态 -->
    <view wx:else class="loading-state">
      <t-loading theme="circular" size="60rpx" />
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 分页 -->
    <view wx:if="{{ fileList.length > 0 }}" class="pagination">
      <t-button theme="default" size="small" variant="outline" icon="chevron-left" bindtap="prevPage" disabled="{{ currentPage <= 1 }}">上一页</t-button>
      <view class="page-indicator">
        <text class="page-current">{{ currentPage }}</text>
        <text class="page-separator">/</text>
        <text class="page-total">{{ totalPages }}</text>
      </view>
      <t-button theme="default" size="small" variant="outline" icon="chevron-right" bindtap="nextPage" disabled="{{ currentPage >= totalPages }}">下一页</t-button>
    </view>
  </view>

  <!-- Toast -->
  <t-toast id="t-toast" />
</view>
