.page-container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding-bottom: 40rpx;
}

/* ========== 头部样式 ========== */
.header {
  background: linear-gradient(135deg, #0052d9 0%, #4364f7 50%, #6fb1fc 100%);
  color: #ffffff;
  padding: 24rpx 32rpx;
  padding-top: calc(env(safe-area-inset-top) + 24rpx);
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 20rpx;
}

.header-left {
  flex: 1;
  min-width: 280rpx;
}

.logo-area {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.logo-icon {
  font-size: 48rpx;
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.title-area {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.subtitle {
  font-size: 22rpx;
  opacity: 0.85;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.theme-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.theme-btn:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.3);
}

.btn-group {
  display: flex;
  gap: 12rpx;
}

/* ========== 上传区域 ========== */
.upload-section {
  margin: 24rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.upload-tip {
  font-size: 24rpx;
  color: var(--text-placeholder);
}

.upload-queue {
  width: 100%;
  margin-top: 16rpx;
}

.upload-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background-color: var(--bg-color);
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}

.upload-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.upload-name {
  font-size: 26rpx;
  color: var(--text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.upload-status {
  font-size: 24rpx;
  margin-left: 16rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.upload-status.uploading {
  color: var(--primary-color);
  background: rgba(0, 82, 217, 0.1);
}

.upload-status.success {
  color: var(--success-color);
  background: rgba(0, 133, 66, 0.1);
}

.upload-status.fail {
  color: var(--danger-color);
  background: rgba(213, 73, 65, 0.1);
}

/* ========== 文件列表 ========== */
.file-list-section {
  margin: 0 24rpx 24rpx;
  padding: 0;
  overflow: hidden;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
  flex-wrap: wrap;
  gap: 16rpx;
}

.list-title-area {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.file-count {
  font-size: 22rpx;
  color: var(--primary-color);
  background: rgba(0, 82, 217, 0.08);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.list-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.selected-badge {
  background: linear-gradient(135deg, #0052d9 0%, #4364f7 100%);
  color: #ffffff;
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* ========== 表格样式 ========== */
.file-table {
  font-size: 24rpx;
}

.table-header {
  display: flex;
  padding: 20rpx 16rpx;
  background-color: var(--bg-color);
  font-weight: 500;
  color: var(--text-secondary);
  border-bottom: 2rpx solid var(--border-color);
}

.table-body {
  max-height: 700rpx;
}

/* 斑马纹表格行 */
.table-row {
  display: flex;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid var(--border-color);
  align-items: center;
  transition: background-color 0.2s;
}

/* 奇数行 - 默认背景色 */
.table-row.zebra-odd {
  background-color: var(--card-bg);
}

/* 偶数行 - 斑马纹浅蓝色 */
.table-row.zebra-even {
  background-color: rgba(0, 82, 217, 0.03);
}

/* 选中行样式 */
.table-row.selected {
  background-color: rgba(0, 82, 217, 0.1) !important;
}

.table-row:active {
  background-color: rgba(0, 82, 217, 0.12);
}

.th, .td {
  display: flex;
  align-items: center;
}

.th-checkbox, .td-checkbox {
  width: 80rpx;
  height: 80rpx;
  justify-content: center;
  align-items: center;
  transition: all 0.2s;
}

.th-checkbox:active, .td-checkbox:active {
  opacity: 0.7;
  transform: scale(0.9);
}

.th-name, .td-name {
  flex: 1;
  padding: 0 16rpx;
}

.th-op, .td-op {
  width: 220rpx;
  justify-content: flex-end;
}

/* 文件信息 */
.file-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.file-name {
  color: var(--text-primary);
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 26rpx;
}

/* 图标操作按钮组 */
.action-btns {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: transparent;
  transition: all 0.2s;
}

.action-btn:active {
  background-color: rgba(0, 0, 0, 0.05);
  transform: scale(0.92);
}

.action-btn-danger:active {
  background-color: rgba(213, 73, 65, 0.1);
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon-area {
  width: 180rpx;
  height: 180rpx;
  background: linear-gradient(135deg, #f0f5ff 0%, #e6f0ff 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-placeholder);
  margin-bottom: 32rpx;
}

/* ========== 加载状态 ========== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-placeholder);
  margin-top: 20rpx;
}

/* ========== 分页 ========== */
.pagination {
  padding: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 24rpx;
  background-color: var(--card-bg);
  border-top: 1rpx solid var(--border-color);
}

.page-indicator {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  padding: 0 16rpx;
}

.page-current {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.page-separator {
  font-size: 24rpx;
  color: var(--text-placeholder);
}

.page-total {
  font-size: 24rpx;
  color: var(--text-secondary);
}
