.page-container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding-bottom: 40rpx;
}

/* 头部样式 */
.header {
  background: linear-gradient(135deg, var(--primary-color) 0%, #003a94 100%);
  color: #ffffff;
  padding: 24rpx 32rpx;
  padding-top: calc(env(safe-area-inset-top) + 24rpx);
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
}

.header-left {
  flex: 1;
  min-width: 300rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.theme-toggle {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  font-size: 32rpx;
}

/* 上传区域 */
.upload-section {
  margin: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.upload-tip {
  font-size: 24rpx;
  color: var(--text-placeholder);
}

.upload-queue {
  width: 100%;
  margin-top: 16rpx;
}

.upload-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  background-color: var(--bg-color);
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.upload-name {
  font-size: 24rpx;
  color: var(--text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.upload-status {
  font-size: 24rpx;
  margin-left: 16rpx;
}

.upload-status.uploading {
  color: var(--primary-color);
}

.upload-status.success {
  color: var(--success-color);
}

.upload-status.fail {
  color: var(--danger-color);
}

/* 文件列表 */
.file-list-section {
  margin: 0 24rpx 24rpx;
  padding: 0;
  overflow: hidden;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background-color: var(--header-bg);
  color: var(--header-text);
  flex-wrap: wrap;
  gap: 16rpx;
}

.list-title {
  font-size: 28rpx;
  font-weight: 500;
}

.list-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.selected-count {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 表格样式 */
.file-table {
  font-size: 24rpx;
}

.table-header {
  display: flex;
  padding: 20rpx 16rpx;
  background-color: var(--bg-color);
  font-weight: 500;
  color: var(--text-secondary);
  border-bottom: 1rpx solid var(--border-color);
}

.table-body {
  max-height: 700rpx;
}

.table-row {
  display: flex;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid var(--border-color);
  background-color: var(--card-bg);
  align-items: center;
}

.table-row.selected {
  background-color: rgba(0, 82, 217, 0.05);
}

.table-row:last-child {
  border-bottom: none;
}

.th, .td {
  display: flex;
  align-items: center;
}

.th-checkbox, .td-checkbox {
  width: 60rpx;
  justify-content: center;
}

.th-name, .td-name {
  flex: 1;
  padding: 0 16rpx;
}

.th-size, .td-size {
  width: 120rpx;
  justify-content: center;
}

.th-type, .td-type {
  width: 140rpx;
  justify-content: center;
}

.th-op, .td-op {
  width: 360rpx;
  justify-content: flex-end;
}

.file-name {
  color: var(--link-color);
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.op-buttons {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 128rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  color: var(--text-placeholder);
  margin-bottom: 32rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--text-placeholder);
}

/* 分页 */
.pagination {
  padding: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 24rpx;
  background-color: var(--card-bg);
}

.page-info {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* Toast */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  padding: 24rpx 48rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  z-index: 9999;
  opacity: 0.9;
}

.toast-success {
  background-color: var(--success-color);
  color: #ffffff;
}

.toast-warning {
  background-color: var(--warning-color);
  color: #ffffff;
}

.toast-error {
  background-color: var(--danger-color);
  color: #ffffff;
}
