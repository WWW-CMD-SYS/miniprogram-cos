.detail-page {
  min-height: 100vh;
  background-color: var(--bg-color);
}

.header {
  background: linear-gradient(135deg, var(--primary-color) 0%, #003a94 100%);
  color: #ffffff;
  padding: 24rpx 32rpx;
  padding-top: calc(env(safe-area-inset-top) + 24rpx);
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.back-btn {
  width: 120rpx;
  font-size: 28rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
}

.content {
  padding: 24rpx;
}

.card {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 预览区域 */
.preview-area {
  min-height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-loading {
  padding: 120rpx 0;
  color: var(--text-placeholder);
}

.preview-image {
  width: 100%;
  max-height: 600rpx;
}

.preview-text {
  width: 100%;
  height: 600rpx;
  background-color: var(--bg-color);
  padding: 24rpx;
  font-size: 24rpx;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-all;
  box-sizing: border-box;
}

.preview-unsupported {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.unsupported-icon {
  font-size: 128rpx;
  margin-bottom: 24rpx;
}

.unsupported-text {
  color: var(--text-placeholder);
}

/* 文件信息 */
.info-card {
  padding: 24rpx;
}

.info-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: var(--text-placeholder);
  flex-shrink: 0;
  margin-right: 24rpx;
  line-height: 1.5;
}

.info-value {
  font-size: 26rpx;
  color: var(--text-primary);
  word-break: break-all;
  text-align: right;
  flex: 1;
  line-height: 1.5;
}

.path-value {
  font-size: 22rpx;
  font-family: monospace;
  background-color: var(--bg-color);
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  text-align: left;
}

/* 文件路径项特殊布局 */
.info-item-path {
  flex-direction: column;
  align-items: flex-start;
}

.info-item-path .info-label {
  margin-bottom: 12rpx;
}

.info-item-path .info-value {
  width: 100%;
  text-align: left;
}

/* 存储类型标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background-color: rgba(0, 82, 217, 0.1);
  color: #0052d9;
}

.tag-warning {
  background-color: rgba(255, 158, 0, 0.1);
  color: #ff9e00;
}

.tag-success {
  background-color: rgba(0, 168, 84, 0.1);
  color: #00a854;
}

.tag-default {
  background-color: rgba(153, 153, 153, 0.1);
  color: #666;
}

.tag-danger {
  background-color: rgba(227, 77, 89, 0.1);
  color: #e34d59;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  margin-top: 40rpx;
  padding: 0 8rpx;
}

.action-buttons t-button {
  flex: 1;
  --td-button-primary-bg-color: linear-gradient(135deg, #0052d9 0%, #003bb3 100%);
  --td-button-primary-active-bg-color: linear-gradient(135deg, #0041b3 0%, #002d80 100%);
  --td-button-danger-bg-color: linear-gradient(135deg, #e34d59 0%, #c9353f 100%);
  --td-button-danger-active-bg-color: linear-gradient(135deg, #c9353f 0%, #a02830 100%);
  --td-button-border-radius: 12rpx;
  --td-button-font-weight: 500;
}

/* Toast */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  padding: 24rpx 48rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  z-index: 9999;
  opacity: 0.9;
}

.toast-success {
  background-color: var(--success-color);
  color: #ffffff;
}

.toast-warning {
  background-color: var(--warning-color);
  color: #ffffff;
}

.toast-error {
  background-color: var(--danger-color);
  color: #ffffff;
}
